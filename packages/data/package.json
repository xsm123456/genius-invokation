{
  "name": "@gi-tcg/data",
  "version": "0.20.2+gi-6-5-0",
  "description": "Standard card data for Genius Invokation TCG",
  "type": "module",
  "types": "./dist/index.d.ts",
  "repository": {
    "url": "https://github.com/piovium/genius-invokation",
    "directory": "packages/data"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./internal/*": "./src/*.ts"
  },
  "scripts": {
    "regenerate_data": "gnx ./scripts/generators/index.ts",
    "check": "tsc --noEmit",
    "build": "tsdown"
  },
  "peerDependencies": {
    "@gi-tcg/core": "workspace:*"
  },
  "devDependencies": {
    "@gi-tcg/assets-manager": "workspace:*",
    "@gi-tcg/config": "workspace:*",
    "@microsoft/tsdoc": "^0.14.2",
    "case-anything": "^2.1.13",
    "glob": "^11.0.3"
  }
}
