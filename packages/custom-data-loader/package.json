{
  "name": "@gi-tcg/custom-data-loader",
  "private": true,
  "version": "0.20.2+gi-6-0-0",
  "description": "Provides an easy way to load your custom data for GI-TCG",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "check": "tsc --noEmit",
    "build": "tsdown"
  },
  "dependencies": {
    "@gi-tcg/data": "workspace:*"
  },
  "peerDependencies": {
    "@gi-tcg/core": "workspace:*"
  },
  "devDependencies": {
    "@gi-tcg/assets-manager": "workspace:*",
    "rolldown": "^1.0.0-rc.15",
    "rolldown-plugin-dts": "^0.23.2",
    "@gi-tcg/deck-builder": "workspace:*",
    "@gi-tcg/web-ui-core": "workspace:*",
    "@gi-tcg/typings": "workspace:*",
    "monaco-editor": "^0.52.2",
    "solid-js": "catalog:",
    "vite": "catalog:",
    "vite-plugin-solid": "catalog:"
  }
}
